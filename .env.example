# ============================================
# AI Interview Platform - Environment Variables
# ============================================

# ─── Frontend (Next.js) ────────────────────────────────────────────────────
NEXT_PUBLIC_TAVUS_API_KEY=your_tavus_api_key_here
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Backend (FastAPI) ─────────────────────────────────────────────────────

# Gemini API for AI question generation
GEMINI_API_KEY=your_gemini_api_key_here

# Judge0 for code execution (self-hosted or cloud)
JUDGE0_API_KEY=your_judge0_rapidapi_key_here
JUDGE0_HOST=http://localhost:2358

# PostgreSQL database connection
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interview

# JWT secret for authentication (use a strong random string)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me

# Tavus AI for video interviews
TAVUS_API_KEY=your_tavus_api_key_here

# Google OAuth credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000
